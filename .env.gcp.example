# Vertex AI / Google Cloud pipeline config. Copy to .env (gitignored) and fill in.
# Auth uses Application Default Credentials:  gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash-001
# Vertex AI supervised tuning stages its training data on GCS:
GCS_BUCKET=your-bucket-name
